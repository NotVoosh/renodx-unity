#include "../../common.hlsli"

Texture2D<float4> t4 : register(t4);
Texture2D<float4> t3 : register(t3);
Texture2D<float4> t2 : register(t2);
Texture2DArray<float4> t1 : register(t1);
Texture2DArray<float4> t0 : register(t0);
SamplerState s1_s : register(s1);
SamplerState s0_s : register(s0);
cbuffer cb1 : register(b1){
  float4 cb1[58];
}
cbuffer cb0 : register(b0){
  float4 cb0[18];
}

void main(
  float4 v0 : SV_POSITION0,
  float2 v1 : uv0,
  out float4 o0 : SV_Target0)
{
  float4 r0,r1,r2,r3,r4,r5;
  uint4 bitmask, uiDest;
  float4 fDest;

  r0.z = 0;
  r1.xyz = t4.Sample(s1_s, v1.xy).xyw;
  r1.x = r1.z * r1.x;
  r1.xy = r1.xy * float2(2,2) + float2(-1,-1);
  r1.xy = cb0[16].zz * r1.xy;
  r1.zw = float2(-0.5,-0.5) + v1.xy;
  r0.w = dot(r1.zw, r1.zw);
  r2.x = r0.w + r0.w;
  r0.w = rsqrt(r0.w);
  r1.zw = r1.zw * r0.ww;
  r0.w = log2(r2.x);
  r0.w = cb0[16].y * r0.w;
  r0.w = exp2(r0.w);
  r0.w = min(1, r0.w);
  r0.w = cb0[16].x * r0.w;
  r1.xy = r1.xy * r0.ww;
  r1.xy = -r1.zw * r1.xy + v1.xy;
  r2.xw = float2(0,0);
  r2.yz = cb0[0].yx;
  r0.xy = r1.xy * cb0[2].xy + r2.xy;
  r0.xyz = t1.Sample(s0_s, r0.xyz).xyz;
  r0.x = renodx::color::y::from::NTSC1953(r0.xyz);
  r3.z = 0;
  r3.xy = r1.xy * cb0[2].xy + -r2.xy;
  r3.xyz = t1.Sample(s0_s, r3.xyz).xyz;
  r0.y = renodx::color::y::from::NTSC1953(r3.xyz);
  r0.z = min(r0.x, r0.y);
  r0.x = max(r0.x, r0.y);
  r3.z = 0;
  r3.xy = r1.xy * cb0[2].xy + -r2.zw;
  r3.xyz = t1.Sample(s0_s, r3.xyz).xyz;
  r0.y = renodx::color::y::from::NTSC1953(r3.xyz);
  r0.z = min(r0.z, r0.y);
  r0.x = max(r0.x, r0.y);
  r3.xy = r1.xy * cb0[2].xy + r2.zw;
  r3.z = 0;
  r3.xyz = t1.Sample(s0_s, r3.xyz).xyz;
  r0.y = renodx::color::y::from::NTSC1953(r3.xyz);
  r0.z = min(r0.z, r0.y);
  r0.x = max(r0.x, r0.y);
  r0.y = -9.99999997e-007 + r0.z;
  r0.z = r0.x + -r0.y;
  r0.z = saturate(cb0[7].w / r0.z);
  r3.xy = cb0[2].xy * r1.xy;
  r3.z = 0;
  r3.xyzw = t1.Sample(s0_s, r3.xyz).xyzw;
  r3.xyzw = max(float4(0,0,0,0), r3.xyzw);
  r3.xyzw = min(float4(1000000,1000000,1000000,1000000), r3.xyzw);
  r1.z = renodx::color::y::from::NTSC1953(r3.xyz);
  r0.y = r1.z * 2 + -r0.y;
  r0.x = r0.y + -r0.x;
  r0.x = r0.x * r0.z;
  r4.xyzw = -r2.xyzw + r1.xyxy;
  r2.xyzw = r2.xyzw + r1.xyxy;
  r2.xyzw = cb1[50].xyxy * r2.zwxy;
  r4.xyzw = cb1[50].xyxy * r4.xyzw;
  r5.xy = (uint2)r4.xy;
  r4.xy = (uint2)r4.zw;
  r5.zw = float2(0,0);
  r0.y = t0.Load(r5.xyzw).x;
  r0.y = cb1[57].x * r0.y + cb1[57].y;
  r0.y = 1 / r0.y;
  r5.xy = (uint2)r2.zw;
  r2.xy = (uint2)r2.xy;
  r5.zw = float2(0,0);
  r0.z = t0.Load(r5.xyzw).x;
  r0.z = cb1[57].x * r0.z + cb1[57].y;
  r0.z = 1 / r0.z;
  r1.z = max(r0.z, r0.y);
  r0.y = min(r0.z, r0.y);
  r4.zw = float2(0,0);
  r0.z = t0.Load(r4.xyzw).x;
  r0.z = cb1[57].x * r0.z + cb1[57].y;
  r0.z = 1 / r0.z;
  r1.z = max(r1.z, r0.z);
  r2.zw = float2(0,0);
  r1.w = t0.Load(r2.xyzw).x;
  r1.w = cb1[57].x * r1.w + cb1[57].y;
  r1.w = 1 / r1.w;
  r1.z = max(r1.z, r1.w);
  r0.y = min(r0.y, r0.z);
  r0.z = -cb0[9].y + r0.z;
  r0.z = cb0[9].z / abs(r0.z);
  r0.y = min(r0.y, r1.w);
  r0.y = r1.z + -r0.y;
  r0.y = 9.99999975e-006 + r0.y;
  r0.y = saturate(cb0[7].y / r0.y);
  r0.x = r0.x * r0.y;
  r0.x = cb0[7].x * r0.x;
  r0.x = max(-cb0[7].z, r0.x);
  r0.x = min(cb0[7].z, r0.x);
  r0.y = r0.z > 1 ? 1.000000 : 0;
  r0.z = saturate(cb0[9].x * r0.z);
  r0.y = max(r0.y, r0.z);
  r0.x = r0.x * r0.y + 1;
  r0.xyz = r3.xyz * r0.xxx;
  r0.xyz = r0.xyz / cb0[6].xxx;
  r2.xyz = saturate(r0.xyz);
  r2.xyz = float3(1,1,1) + -r2.xyz;
  r4.xyz = r2.yxx * r0.xyz;
  r2.xyz = r4.xyz * r2.zzy;
  r2.xyz = r2.xyz * cb0[8].www + float3(1,1,1);
  r2.xyz = r2.xyz * r0.xyz;
  r0.x = renodx::color::y::from::NTSC1953(r0.xyz);
  r0.y = renodx::color::y::from::NTSC1953(r2.xyz);
  r0.y = 9.99999975e-005 + r0.y;
  r0.x = r0.x / r0.y;
  r0.xyz = r2.xyz * r0.xxx;
  r2.xyz = handleUserLUT(r0.xyz, t2, s0_s, 0);
  r0.xyz = renodx::color::srgb::EncodeSafe(r0.xyz);
  r2.xyz = r2.xyz + -r0.xyz;
  r0.xyz = cb0[10].zzz * r2.xyz + r0.xyz;
  r0.xyz = renodx::color::srgb::DecodeSafe(r0.xyz);
  r1.z = max(r0.y, r0.z);
  r1.z = max(r1.z, r0.x);
  r1.w = min(r0.y, r0.z);
  r1.w = min(r1.w, r0.x);
  r1.z = saturate(r1.z + -r1.w);
  r1.z = 1 + -r1.z;
  r1.z = cb0[8].z * r1.z;
  r1.w = renodx::color::y::from::NTSC1953(r0.xyz);
  r2.xyz = -r1.www + r0.xyz;
  r2.xyz = r1.zzz * r2.xyz + float3(1,1,1);
  r0.xyz = r0.xyz * r2.xyz + float3(-0.5,-0.5,-0.5);
  r0.xyz = r0.xyz * cb0[8].yyy + float3(0.5,0.5,0.5);
  r2.xyz = saturate(r0.xyz);
  r4.xyz = float3(1,1,1) + -r2.xyz;
  r4.xyz = r4.xyz + r4.xyz;
  r5.xyz = -r2.xyz * cb0[10].yyy + float3(1,1,1);
  r4.xyz = -r4.xyz * r5.xyz + float3(1,1,1);
  r5.xyz = cb0[10].yyy * r2.xyz;
  r2.xyz = r5.xyz * r2.xyz;
  r2.xyz = r2.xyz + r2.xyz;
  r2.xyz = r1.w < 0.5 ? r2.xyz : r4.xyz;
  r2.xyz = r2.xyz + -r0.xyz;
  r0.xyz = cb0[10].xxx * r2.xyz + r0.xyz;
  r1.zw = cb0[0].zw * r1.xy;
  r2.xy = -cb0[12].xy + r1.xy;
  r1.x = dot(r1.zw, float2(0.0671105608,0.00583714992));
  r1.x = frac(r1.x);
  r1.x = 52.9829178 * r1.x;
  r1.x = frac(r1.x);
  r1.x = -0.5 + r1.x;
  r1.x = cb0[9].w * r1.x;
  r0.xyz = r0.xyz * cb0[8].xxx + r1.xxx;
  r0.xyz = max(float3(0,0,0), r0.xyz);
  r0.xyz = -cb0[11].xyz + r0.xyz;
  r2.z = cb0[12].z * r2.y;
  r1.x = dot(r2.xz, r2.xz);
  r1.x = -cb0[13].z + r1.x;
  r1.y = cb0[13].y + -cb0[13].z;
  r1.x = saturate(r1.x / r1.y);
  r1.y = 1 + -cb0[11].w;
  r1.x = r1.y + r1.x;
  r1.x = saturate(-cb0[13].x + r1.x);
  r0.xyz = r1.xxx * r0.xyz + cb0[11].xyz;
  r0.xyz = cb0[6].xxx * r0.xyz;
  r1.xyz = t3.Sample(s1_s, v1.xy).xyz;
  r1.w = -r1.y * r0.w + 1;
  r1.xyz = r1.xyz * r0.www;
  r0.xyz = r1.www * r0.xyz;
  r0.xyz = r1.xyz * cb0[17].xyz + r0.xyz;
  r0.w = 1;
  r0.xyzw = r0.xyzw + -r3.xyzw;
  o0.xyzw = cb0[13].wwww * r0.xyzw + r3.xyzw;
  if (injectedData.countOld == injectedData.countNew) {
    o0.xyz = GradeAndDisplayMap(o0.xyz);
  }
  if (injectedData.countOld == injectedData.countNew) {
    o0.xyz = PostToneMapScale(o0.xyz);
  }
  return;
}