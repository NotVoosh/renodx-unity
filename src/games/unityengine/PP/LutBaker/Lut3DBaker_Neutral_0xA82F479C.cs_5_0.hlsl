    r4.y = dot(float3(-0.210182,1.158200,0.000324281), r3.xyz);
    r4.z = dot(float3(-0.041812,-0.118169,1.068670), r3.xyz);
    r3.xyz = cb0[2].xyz * r4.xyz;
    r4.x = dot(r3.xyz, cb0[4].xyz);
    r4.y = dot(r3.xyz, cb0[5].xyz);
    r4.z = dot(r3.xyz, cb0[6].xyz);
    float3 preLGG = r4.xyz;
    r3.xyz = r4.xyz * cb0[9].xyz + cb0[7].xyz;
    r4.xyz = saturate(r3.xyz * renodx::math::FLT_MAX + float3(0.5,0.5,0.5));
    r4.xyz = r4.xyz * float3(2,2,2) + float3(-1,-1,-1);
    r3.xyz = log2(abs(r3.xyz));
    r3.xyz = cb0[8].xyz * r3.xyz;
