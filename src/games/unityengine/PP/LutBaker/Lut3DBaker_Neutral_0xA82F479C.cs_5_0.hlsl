    float compression_scale;
    if (injectedData.colorGradeInternalLUTShaper == 0.f) {
    preCG = arriDecode(r0.xyz);
    r1.xyz = r0.xyz + float3(-0.4135884,-0.4135884,-0.4135884);
    r1.xyz = r1.xyz * cb0[3].zzz + float3(0.4135884,0.4135884,0.4135884);
    r2.xyz = arriDecode(r1.xyz);
    } else {
      r0.xyz = lutShaper(r0.xyz, true);
      preCG = r0.xyz;
      GamutCompression(r0.xyz, compression_scale);
      r0.xyz = renodx::color::arri::logc::c1000::Encode(r0.xyz, false);
      r1.xyz = r0.xyz + float3(-0.4135884,-0.4135884,-0.4135884);
      r1.xyz = r1.xyz * cb0[3].zzz + float3(0.4135884,0.4135884,0.4135884);
      r2.xyz = renodx::color::arri::logc::c1000::Decode(r1.xyz, false);
      GamutDecompression(r2.xyz, compression_scale);
    }
    r3.x = dot(float3(0.390405,0.549941,0.00892632), r2.xyz);
    r3.y = dot(float3(0.0708416,0.963172,0.00135775), r2.xyz);
    r3.z = dot(float3(0.0231082,0.128021,0.936245), r2.xyz);
    r3.xyz = cb0[1].xyz * r3.xyz;
