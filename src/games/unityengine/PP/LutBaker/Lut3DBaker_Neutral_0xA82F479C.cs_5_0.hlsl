    r1.z = saturate(r1.z);
    r1.z = r1.z + r3.z;
    r3.xyz = float3(-0.5,0.5,-1.5) + r1.zzz;
    r1.w = r3.x > 1 ? r3.z : r3.x;
    r1.z = r3.x < 0 ? r3.y : r1.w;
    r3.xyz = float3(1.0, 2.0 / 3.0, 1.0 / 3.0) + r1.zzz;
    r3.xyz = frac(r3.xyz);
    r3.xyz = r3.xyz * float3(6,6,6) + float3(-3,-3,-3);
    r3.xyz = saturate(float3(-1,-1,-1) + abs(r3.xyz));
    r3.xyz = float3(-1,-1,-1) + r3.xyz;
    r3.xyz = r5.zzz * r3.xyz + float3(1,1,1);
    r4.yzw = r4.xxx * r3.xyz;
    r0.w = dot(cb0[3].yy, r0.ww);
    r1.z = dot(r4.yzw, float3(0.212672904,0.715152204,0.0721750036));
    r3.xyz = r4.xxx * r3.xyz + -r1.zzz;
    r3.xyz = r0.www * r3.xyz + r1.zzz;
    GamutDecompression(r3.xyz, compression_scale);
    r3.xyz = lerp(preCG, r3.xyz, injectedData.colorGradeInternalLUTStrength);
    //r3.xyz = max(float3(0,0,0), r3.xyz);
    r0.xyz = lutShaper(r0.xyz, true);
    r4.x = dot(float3(0.4397010, 0.3829780, 0.1773350), r0.xyz);
    r4.y = dot(float3(0.0897923, 0.8134230, 0.0967616), r0.xyz);
    r4.z = dot(float3(0.0175440, 0.1115440, 0.8707040), r0.xyz);
    preCG = r4.xyz;
    r0.xyz = acesccEncode(r4.xyz);
    r0.xyz = float3(-0.4135884,-0.4135884,-0.4135884) + r0.xyz;
    r0.xyz = r0.xyz * cb0[3].zzz + float3(0.4135884,0.4135884,0.4135884);
    r6.xyz = acescc::Decode(r0.xyz);
    r0.x = dot(float3(1.45143926,-0.236510754,-0.214928567), r6.xyz);
    r0.y = dot(float3(-0.0765537769,1.17622972,-0.0996759236), r6.xyz);
    r0.z = dot(float3(0.00831614807,-0.00603244966,0.997716308), r6.xyz);
    r4.x = dot(float3(0.390405,0.549941,0.00892632), r0.xyz);
    r4.y = dot(float3(0.0708416,0.963172,0.00135775), r0.xyz);
    r4.z = dot(float3(0.0231082,0.128021,0.936245), r0.xyz);
    r0.xyz = cb0[1].xyz * r4.xyz;
    r4.x = dot(float3(2.858470,-1.628790,-0.024891), r0.xyz);
    r4.y = dot(float3(-0.210182,1.158200,0.000324281), r0.xyz);
    r4.z = dot(float3(-0.041812,-0.118169,1.068670), r0.xyz);
    r0.xyz = cb0[2].xyz * r4.xyz;
    r4.x = dot(r0.xyz, cb0[4].xyz);
    r4.y = dot(r0.xyz, cb0[5].xyz);
    r4.z = dot(r0.xyz, cb0[6].xyz);
    preLGG = r4.xyz;
    r0.xyz = r4.xyz * cb0[9].xyz + cb0[7].xyz;
    r4.xyz = saturate(r0.xyz * renodx::math::FLT_MAX + float3(0.5,0.5,0.5));
    r4.xyz = r4.xyz * float3(2,2,2) + float3(-1,-1,-1);
    r0.xyz = log2(abs(r0.xyz));
    r0.xyz = cb0[8].xyz * r0.xyz;
    r0.xyz = exp2(r0.xyz);
    r0.xyz = r4.xyz * r0.xyz;
    r0.xyz = liftGammaGainScaling(r0.xyz, preLGG, cb0[7].xyz, cb0[8].xyz, cb0[9].xyz);
    r0.xyz = max(float3(0,0,0), r0.xyz);
    r0.w = step(r0.z, r0.y);
    r4.xy = r0.zy;
    r4.zw = float2(-1.0, 2.0 / 3.0);
    r5.xy = -r4.xy + r0.yz;
    r5.zw = float2(1,-1);
    r4.xyzw = r0.wwww * r5.xyzw + r4.xyzw;
    r0.w = step(r4.x, r0.x);
    r5.xyz = r4.xyw;
    r5.w = r0.x;
    r4.xyw = r5.wyx;
    r4.xyzw = r4.xyzw + -r5.xyzw;
    r4.xyzw = r0.wwww * r4.xyzw + r5.xyzw;
    r0.w = min(r4.w, r4.y);
    r0.w = r4.x + -r0.w;
    r1.z = r4.w + -r4.y;
    r1.w = r0.w * 6.0 + 0.0001;
    r1.z = r1.z / r1.w;
    r1.z = r4.z + r1.z;
    r5.x = abs(r1.z);
    r1.z = 0.0001 + r4.x;
    r5.z = r0.w / r1.z;
    r5.yw = float2(0.25,0.25);
    r0.w = t0.SampleLevel(s0_s, r5.xy, 0).y;
    r0.w = saturate(r0.w);
    r0.w = r0.w + r0.w;
    r1.z = t0.SampleLevel(s0_s, r5.zw, 0).z;
    r1.z = saturate(r1.z);
    r0.w = dot(r1.zz, r0.ww);
    r6.x = dot(r0.xyz, float3(0.212672904,0.715152204,0.0721750036));
    r6.yw = float2(0.25,0.25);
    r0.x = t0.SampleLevel(s0_s, r6.xy, 0).w;
    r0.x = saturate(r0.x);
    r0.x = r0.x * r0.w;
    r6.z = cb0[3].x + r5.x;
    r0.y = t0.SampleLevel(s0_s, r6.zw, 0).x;
    r0.y = saturate(r0.y);
    r0.y = r0.y + r6.z;
    r0.yzw = float3(-0.5,0.5,-1.5) + r0.yyy;
    float value = r0.y;
    r0.y = value > 1 ? r0.w : r0.y;
    r0.y = value < 0 ? r0.z : r0.y;
    r0.yzw = float3(1.0, 2.0 / 3.0, 1.0 / 3.0) + r0.yyy;
    r0.yzw = frac(r0.yzw);
    r0.yzw = r0.yzw * float3(6,6,6) + float3(-3,-3,-3);
    r0.yzw = saturate(float3(-1,-1,-1) + abs(r0.yzw));
    r0.yzw = float3(-1,-1,-1) + r0.yzw;
    r0.yzw = r5.zzz * r0.yzw + float3(1,1,1);
    r4.yzw = r4.xxx * r0.yzw;
    r0.x = dot(cb0[3].yy, r0.xx);
    r1.z = dot(r4.yzw, float3(0.212672904,0.715152204,0.0721750036));
    r0.yzw = r4.xxx * r0.yzw + -r1.zzz;
    r0.xyz = r0.xxx * r0.yzw + r1.zzz;
    r4.y = dot(float3(0.695452213,0.140678704,0.163869068), r0.xyz);
    r4.z = dot(float3(0.0447945632,0.859671116,0.0955343172), r0.xyz);
    r4.w = dot(float3(-0.00552588282,0.00402521016,1.00150073), r0.xyz);
    r4.yzw = lerp(preCG, r4.yzw, injectedData.colorGradeInternalLUTStrength);
    r4.xyz = Ap1AcesTonemap(r4.yzw, 0);
    r0.x = step(r2.z, r2.y);
    r0.y = r1.y * 0.179999992 + -r2.z;
    r0.x = r0.x * r0.y + r2.z;
    r0.y = step(r0.x, r2.x);
    r0.z = r1.x * 0.179999992 + -r0.x;
    r0.x = r0.y * r0.z + r0.x;
    if (injectedData.toneMapType == 0.f) {
      r0.yzw = min(float3(1, 1, 1), r3.xyz);
    } else {
      r3.xyz = CorrectHueAndChrominanceOKLAB(r3.xyz, renodx::tonemap::renodrt::NeutralSDR(r3.xyz, true), injectedData.toneMapHueShift, injectedData.toneMapSDRBlowout);
      r0.yzw = r3.xyz;
    }
    r0.yzw = max(r0.yzw, r4.xyz);
    r0.x = -0.800000012 + r0.x;
    r0.x = saturate(5.00000048 * r0.x);
    r1.x = r0.x * -2 + 3;
    r0.x = r0.x * r0.x;
    r0.x = r1.x * r0.x;
    r0.yzw = r0.yzw + -r3.xyz;
    r0.xyz = r0.xxx * r0.yzw + r3.xyz;
    r0.w = 1;
    u0[vThreadID] = r0;
  }
  return;
